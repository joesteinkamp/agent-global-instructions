{
  "_comment": "Reference only. install-hooks.sh merges this into settings.json with the real absolute path to the hooks dir. PreToolUse hooks exit 2 to block; PostToolUse formats and never blocks.",
  "hooks": {
    "PreToolUse": [
      { "matcher": "Edit|Write|MultiEdit|NotebookEdit", "hooks": [ { "type": "command", "command": "$HOME/.claude/hooks/guard-paths.sh" } ] },
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "$HOME/.claude/hooks/guard-bash.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit", "hooks": [ { "type": "command", "command": "$HOME/.claude/hooks/format-edited.sh" } ] }
    ]
  }
}
