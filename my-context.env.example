# Copy this file to `my-context.env` (gitignored) and set your own values.
# customize.sh PARSES it automatically (only the known KEY=VALUE keys below —
# it is not executed as a script), so your answers become the defaults without
# retyping, and nothing personal gets committed. Values may be single- or
# double-quoted and may span multiple lines while inside quotes.

NAME="Your full name"
CALL_ME="your name"
PRONOUNS="they/them"
ROLE="your role"
TIMEZONE="your timezone & city"
CARES="quality work and shipping fast"

# Optional one-line description of where you work. Leave empty to omit the line.
ENVIRONMENT=""

# How you preview/test web & HTML work: tailscale | local | none
PREVIEW="local"
TS_HOST="your-host.ts.net"
TS_IP=""

# aggressive | balanced
AUTONOMY="aggressive"

# Roles you draw from when staffing an agent team (comma-separated)
TEAM_ROLES="front-end engineer, back-end engineer, technical architect, product designer, UI designer, UX researcher"

# Which sections to include (y/n)
INC_MEMORY="y"
INC_TEAMS="y"
INC_WORKTREES="y"
INC_IMPROVE="y"
INC_TOOLS="y"
INC_ARTIFACTS="y"
INC_PROJECT="y"
INC_DOCS="y"
INC_CORRECTIONS="y"
INC_CHANGELOG="y"

# Per-MCP "when to use" rules. Easiest: run `./customize.sh --scan-mcp`, which
# detects your servers and writes them to mcp-rules.local (gitignored).

# Where your memory / notes live (drives the memory-OS section's bullets):
#   MEM_KIND = generic | local | mcp | both
#     generic — name no specific store (default; best for the shared template)
#     local   — a file/db store on this machine (e.g. Hermes); set MEM_PATH
#     mcp      — a notes app reached over MCP (e.g. Notion, Obsidian); set MEM_TOOL
#     both     — a local store AND a notes app; set MEM_PATH and MEM_TOOL
MEM_KIND="generic"
MEM_PATH="~/.hermes/"     # used when MEM_KIND is local or both
MEM_TOOL="Notion"         # used when MEM_KIND is mcp or both

# Optional: bypass MEM_KIND entirely and write the bullet list verbatim (multi-line OK).
# MEM_BLOCK='  - A memory store at `~/.your-agent/` ...
#   - Project-level `MEMORY.md` / `memory/` ...'
