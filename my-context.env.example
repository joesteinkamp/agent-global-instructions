# Copy this file to `my-context.env` (gitignored) and set your own values.
# customize.sh sources it automatically so your answers become the defaults —
# no need to retype them, and nothing personal gets committed.

NAME="Your full name"
CALL_ME="your name"
PRONOUNS="they/them"
ROLE="your role"
TIMEZONE="your timezone & city"
CARES="quality work and shipping fast"

# Optional one-line description of where you work. Leave empty to omit the line.
ENVIRONMENT=""

# How you preview/test web & HTML work: tailscale | local | none
PREVIEW="local"
TS_HOST="your-host.ts.net"
TS_IP=""

# aggressive | balanced
AUTONOMY="aggressive"

# Roles you draw from when staffing an agent team (comma-separated)
TEAM_ROLES="front-end engineer, back-end engineer, technical architect, product designer, UI designer, UX researcher"

# Which sections to include (y/n)
INC_MEMORY="y"
INC_TEAMS="y"
INC_ARTIFACTS="y"
INC_PROJECT="y"
INC_DOCS="y"
INC_CORRECTIONS="y"

# Optional: override the bullet list under the memory-OS section (multi-line OK).
# MEM_BLOCK='  - A memory store at `~/.your-agent/` ...
#   - Project-level `MEMORY.md` / `memory/` ...'
