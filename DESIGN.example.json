{
  "$comment": "Example DESIGN.json token contract — the design reference /verify (lens 4) reads and the 'Design system & UI' instruction section points at. Copy into a project as DESIGN.json and fill with your real values. Every top-level key is optional; /verify checks whatever is present and reports drift as a rendered value that isn't on the corresponding scale. This is a sample, not a schema you must match exactly — keep the shape, change the values. Reduced-motion intent (honor prefers-reduced-motion: reduce — drop non-essential transform/opacity animation, keep instant state changes) is a policy, not a token, so it lives here rather than under motion.",

  "color": {
    "bg": "#0d0e12",
    "fg": "#e9eaf0",
    "muted": "#a8adbd",
    "primary": "#7c8cff",
    "accent": "#5cd2c6",
    "border": "#272b37",
    "danger": "#ff6f8b",
    "success": "#5ad19a"
  },

  "type": {
    "family": {
      "sans": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, Menlo, monospace"
    },
    "size": { "xs": "12px", "sm": "14px", "base": "16px", "lg": "20px", "xl": "28px", "2xl": "40px" },
    "leading": { "tight": 1.2, "normal": 1.6 },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 800 }
  },

  "space": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "8": "48px", "12": "72px" },

  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "pill": "999px" },

  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,.2)",
    "md": "0 4px 16px rgba(0,0,0,.28)",
    "lg": "0 12px 40px rgba(0,0,0,.35)"
  },

  "breakpoints": { "mobile": "390px", "tablet": "768px", "desktop": "1280px", "wide": "1536px" },

  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)",
      "accelerate": "cubic-bezier(0.3, 0, 1, 1)"
    },
    "transition": {
      "hover": { "duration": "fast", "easing": "standard" },
      "enter": { "duration": "base", "easing": "decelerate" },
      "exit": { "duration": "fast", "easing": "accelerate" }
    }
  }
}
